import machine
import time
import network
import ujson
from umqtt.simple import MQTTClient
import ahtx0
from bh1750 import BH1750

# --- KONFIGURATION ---
WIFI_SSID = "BZTG_local"
WIFI_PASS = "Mittelsenkrechte64"
MQTT_BROKER = "10.12.168.36" 
MQTT_USER   = "NilsMQTT"
MQTT_PASS   = "passwort"
TEAM_ID     = "Nils_Ehsan"

TOPIC_STATUS = f"projektesp/{TEAM_ID}/status"
TOPIC_DATA   = f"projektesp/{TEAM_ID}/data"

# --- HARDWARE ---
# Pins bleiben: SCL=36, SDA=35
i2c = machine.I2C(0, scl=machine.Pin(36), sda=machine.Pin(35), freq=10000)

# Variablen global definieren, damit sie im Loop immer existieren
sensor_aht = None
sensor_bh  = None

try:
    # Explizit Adresse 0x77 für deinen Scan
    sensor_aht = ahtx0.AHT10(i2c, address=0x77)
    sensor_bh  = BH1750(0x23, i2c)
    print("Sensoren erfolgreich initialisiert!")
except Exception as e:
    print("Initialisierungs-Fehler:", e)
    # Programm läuft trotzdem weiter, sendet dann halt 0.0

# --- NETZWERK & MQTT ---
wlan = network.WLAN(network.STA_IF)
wlan.active(True)
wlan.connect(WIFI_SSID, WIFI_PASS)
while not wlan.isconnected():
    time.sleep(0.5)

client = MQTTClient(TEAM_ID + "_Sender", MQTT_BROKER, user=MQTT_USER, password=MQTT_PASS, keepalive=20)
client.set_last_will(TOPIC_STATUS, "offline", retain=True)

try:
    client.connect()
    client.publish(TOPIC_STATUS, "online", retain=True)
    print("WLAN & MQTT bereit.")
except:
    print("MQTT Connect fehlgeschlagen.")

# --- HAUPTSCHLEIFE ---
while True:
    try:
        # Werte nur lesen, wenn Sensor-Objekt existiert
        t = sensor_aht.temperature if sensor_aht else 0.0
        h = sensor_aht.relative_humidity if sensor_aht else 0.0
        l = sensor_bh.measurement if sensor_bh else 0.0
        
        payload = ujson.dumps({
            "temp": round(t, 2),
            "hum": round(h, 2),
            "lux": round(l, 2)
        })
        
        client.publish(TOPIC_DATA, payload)
        print(f"Shell A -> Sende: {payload}")
        
        time.sleep(5)
    except Exception as e:
        print("Loop Fehler:", e)
        time.sleep(5)
        machine.reset()